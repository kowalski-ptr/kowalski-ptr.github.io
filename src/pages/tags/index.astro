---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].sort((a, b) =>
  a[0].localeCompare(b[0], 'pl')
);
---

<Base title="Topics" path="/tags">
  <section class="wrap page">
    <h1>Topics</h1>
    <p class="lead">All note tags. Click one to filter.</p>
    {
      tags.length === 0 ? (
        <p class="empty">No tags yet. They will appear once notes are added.</p>
      ) : (
        <div class="cloud">
          {tags.map(([t, n]) => (
            <a class="tag mono" href={`/tags/${encodeURIComponent(t)}`}>
              #{t}
              <span class="n">{n}</span>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Base>

<style>
  .page {
    padding-top: 48px;
    max-width: 820px;
  }
  h1 {
    font-size: 34px;
    font-weight: 720;
    letter-spacing: -0.02em;
    color: var(--heading);
    margin: 0 0 8px;
  }
  .lead {
    color: var(--muted);
    margin: 0 0 30px;
  }
  .cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: var(--text);
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 7px 14px;
    box-shadow: var(--shadow);
    transition: 0.15s;
  }
  .tag:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }
  .n {
    font-size: 11.5px;
    color: var(--accent);
    font-weight: 600;
  }
  .empty {
    color: var(--muted);
  }
</style>
