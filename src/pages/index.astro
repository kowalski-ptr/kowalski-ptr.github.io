---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import NoteCard from '../components/NoteCard.astro';
import { readingTime } from '../lib/format';
import home from '../content/home.json';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// licznik tagów do sidebara
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

// kategorie do sidebara
const catCounts = new Map<string, number>();
for (const p of posts) catCounts.set(p.data.category, (catCounts.get(p.data.category) ?? 0) + 1);
const topCats = [...catCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 6);
---

<Base path="/">
  <section class="hero">
    <div class="wrap">
      {home.eyebrow && <div class="eyebrow mono">{home.eyebrow}</div>}
      <h1>{home.title}</h1>
      {home.lead && <p class="lead">{home.lead}</p>}
      {
        topTags.length > 0 && (
          <div class="tags-row">
            {topTags.map(([t]) => (
              <a class="chip mono" href={`/tags/${encodeURIComponent(t)}`}>
                #{t}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <div class="wrap">
    <div class="grid">
      <div>
        <h2 class="section-h mono">Latest notes</h2>
        {
          posts.length === 0 ? (
            <p class="empty">
              No notes yet. Add the first one via the <code>/admin</code> panel
              or a file in <code>src/content/posts</code>.
            </p>
          ) : (
            posts.map((p) => (
              <div class="note-wrap">
                <NoteCard
                  href={`/notes/${p.id}`}
                  title={p.data.title}
                  description={p.data.description}
                  category={p.data.category}
                  date={p.data.date}
                  readingTime={readingTime(p.body, p.data.readingTime)}
                  tags={p.data.tags}
                />
              </div>
            ))
          )
        }
      </div>

      <aside>
        {
          topCats.length > 0 && (
            <div class="box">
              <h3>Topics</h3>
              <ul>
                {topCats.map(([c, n]) => (
                  <li>
                    <span>{c}</span>
                    <span class="count mono">{n}</span>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
        <div class="box">
          <h3>{home.aboutTitle}</h3>
          {home.aboutText && <p class="aside-p">{home.aboutText}</p>}
          <a class="aside-link mono" href="/about">more →</a>
        </div>
      </aside>
    </div>
  </div>
</Base>

<style>
  .hero {
    padding: 62px 0 38px;
    border-bottom: 1px solid var(--line-soft);
  }
  .eyebrow {
    font-size: 12.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }
  h1 {
    font-size: clamp(30px, 5vw, 41px);
    line-height: 1.12;
    margin: 14px 0 12px;
    font-weight: 720;
    letter-spacing: -0.022em;
    color: var(--heading);
  }
  .lead {
    font-size: 17.5px;
    color: var(--muted);
    max-width: 620px;
    margin: 0;
  }
  .tags-row {
    display: flex;
    gap: 9px;
    margin-top: 26px;
    flex-wrap: wrap;
  }
  .chip {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 13px;
    background: var(--bg-elev);
    transition: 0.15s;
  }
  .chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 48px;
    padding: 42px 0 24px;
  }
  .section-h {
    font-size: 12.5px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--faint);
    margin: 0 0 18px;
    font-weight: 600;
  }
  .note-wrap + .note-wrap {
    margin-top: 16px;
  }
  .empty {
    color: var(--muted);
  }

  aside .box {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px 20px;
    margin-bottom: 18px;
    background: var(--bg-elev);
    box-shadow: var(--shadow);
  }
  aside h3 {
    margin: 0 0 12px;
    font-size: 14px;
    color: var(--heading);
    font-weight: 680;
  }
  aside ul {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 14px;
  }
  aside li {
    padding: 6px 0;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    font-weight: 500;
  }
  .count {
    color: var(--accent);
    font-weight: 600;
    font-size: 12px;
  }
  .aside-p {
    margin: 0 0 10px;
    font-size: 13.5px;
    color: var(--muted);
  }
  .aside-link {
    font-size: 13px;
    color: var(--accent);
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
