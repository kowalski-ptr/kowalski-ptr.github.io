---
const year = new Date().getFullYear();
---

<footer class="foot">
  <div class="wrap foot-in">
    <span class="mono">// knowbase — Astro + TinaCMS · GitHub Pages</span>
    <span class="foot-right mono">
      <a href="/rss.xml">RSS</a>
      <a href="https://github.com/kowalski-ptr" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="dim">© {year}</span>
    </span>
  </div>
</footer>

<style>
  .foot {
    border-top: 1px solid var(--line);
    margin-top: 64px;
  }
  .foot-in {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 28px 0;
    font-size: 13px;
    color: var(--faint);
  }
  .foot-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .foot-right a:hover {
    color: var(--accent);
  }
  .dim {
    opacity: 0.8;
  }
</style>
